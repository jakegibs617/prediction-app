# =============================================================================
# Prediction App — Environment Configuration
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.
# =============================================================================

# --- Application ---
APP_ENV=development
# development | staging | production
LOG_LEVEL=INFO
# DEBUG | INFO | WARNING | ERROR
SECRET_KEY=REPLACE_WITH_RANDOM_SECRET
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=experimental_prediction_app
POSTGRES_USER=REPLACE_WITH_DB_USER
POSTGRES_PASSWORD=REPLACE_WITH_DB_PASSWORD
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# --- Alpha Vantage (equities, ETFs, forex, commodities, crypto prices) ---
# Free tier: 25 requests/day. Standard and premium tiers available for higher volume.
# Covers equities AND crypto in a single key — recommended first connector for MVP.
# Register and get key: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=REPLACE_WITH_ALPHA_VANTAGE_KEY

# --- FRED (Federal Reserve Economic Data — macroeconomic indicators) ---
# Free. Provides GDP, CPI, unemployment, interest rates, and thousands of series.
# Register at: https://fred.stlouisfed.org/docs/api/api_key.html
# After registering, API keys are issued immediately via email.
FRED_API_KEY=REPLACE_WITH_FRED_KEY

# --- NewsAPI (news headlines) ---
# Free developer tier: 100 requests/day, non-commercial only.
# Business tier required for production or commercial use.
# Register at: https://newsapi.org/register
NEWS_API_KEY=REPLACE_WITH_NEWS_API_KEY

# --- CoinGecko (crypto market data) ---
# Demo tier is free with no key — suitable for low-volume prototyping.
# Pro and Analyst tiers require a paid subscription for higher rate limits.
# Leave empty to use the public demo endpoint (https://api.coingecko.com/api/v3).
# Paid plans and key signup: https://www.coingecko.com/en/api/pricing
COINGECKO_API_KEY=

# --- EIA (U.S. Energy Information Administration) ---
# Free. Provides energy prices, production volumes, inventories, and power data.
# Register at: https://www.eia.gov/opendata/register.php
# Key is issued immediately on the same page after registration.
EIA_API_KEY=REPLACE_WITH_EIA_KEY

# --- Glassnode (crypto on-chain exchange, miner, and holder behavior) ---
# Free and paid API tiers. Provides on-chain market intelligence metrics.
# Register at: https://glassnode.com/
GLASSNODE_API_KEY=REPLACE_WITH_GLASSNODE_KEY

# --- GDELT (Global Database of Events, Language, and Tone) ---
# Fully free, no API key required. Access via public HTTP endpoints.
# Docs and endpoint reference: https://blog.gdeltproject.org/gdelt-2-0-our-global-world-in-realtime/
# No value needed — kept here as a reminder that no key is required.
GDELT_API_KEY=

# --- SEC EDGAR (company filings and real-time disclosures) ---
# No API key required. Set a descriptive User-Agent per SEC fair-access policy.
# Format: "AppName/version your@email.com" or "Your Name your@email.com"
# SEC fair-access policy: https://www.sec.gov/developer
SEC_EDGAR_USER_AGENT=REPLACE_WITH_APPNAME_VERSION_AND_EMAIL

# --- NOAA Climate Data Online (weather and climate events) ---
# Free. Requires a token tied to your email address.
# Request a token at: https://www.ncdc.noaa.gov/cdo-web/token
# Token is emailed within a few minutes of submitting the form.
NOAA_API_TOKEN=REPLACE_WITH_NOAA_TOKEN

# --- USGS (earthquake and geophysical event data) ---
# Fully free, no API key required. Access via public REST endpoints.
# API docs: https://earthquake.usgs.gov/fdsnws/event/1/
# No value needed — kept here as a reminder that no key is required.
USGS_API_KEY=

# --- World Bank Indicators API ---
# Fully free, no API key required.
# API docs: https://datahelpdesk.worldbank.org/knowledgebase/articles/889392
# No value needed — kept here as a reminder.
WORLD_BANK_API_KEY=

# --- IMF Data API ---
# Fully free, no API key required.
# API docs: https://datahelp.imf.org/knowledgebase/articles/667681
# No value needed — kept here as a reminder.
IMF_API_KEY=

# --- Telegram Alerting ---
# Bot token from @BotFather and your personal chat ID.
# To get your chat ID: message your bot once, then visit:
#   https://api.telegram.org/bot<TOKEN>/getUpdates
# and read result[0].message.chat.id
TELEGRAM_BOT_TOKEN=REPLACE_WITH_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=REPLACE_WITH_TELEGRAM_CHAT_ID

# --- Admin UI ---
# Password for local dev HTTP Basic Auth on /admin routes.
# For staging/production, replace with a proper session-based auth system.
ADMIN_PASSWORD=REPLACE_WITH_ADMIN_PASSWORD
# Roles: viewer | operator | admin
# Set the default role for new sessions in staging environments.
ADMIN_DEFAULT_ROLE=viewer

# --- Input Validation ---
MAX_PAYLOAD_BYTES=1048576
# 1 MB max raw API payload size
MAX_SINGLE_PERIOD_CHANGE_PCT=0.20
# Flag price bar moves larger than 20% in a single period (anomaly warning, not rejection)
MAX_TEXT_FIELD_FOR_PROMPT=500
# Max characters of any single external text field included in an LLM prompt

# --- AI Model Configuration ---
# Provider selection: ollama | anthropic | openai | groq
# See docs/model_configuration.md for full setup instructions per provider.
AI_MODEL_PROVIDER=ollama
AI_MODEL_NAME=llama3.2:8b

# Ollama (local, free — default for development)
# Install: https://ollama.com/install.sh  |  Docker: ollama/ollama
# Then: ollama pull llama3.2:8b
OLLAMA_BASE_URL=http://localhost:11434

# Anthropic / Claude (frontier — production recommended)
# Register: https://console.anthropic.com → API Keys
# Recommended models: claude-haiku-4-5-20251001 (high volume), claude-sonnet-4-6 (prediction engine)
ANTHROPIC_API_KEY=REPLACE_WITH_ANTHROPIC_KEY

# OpenAI / GPT (frontier alternative)
# Register: https://platform.openai.com/api-keys
# Recommended models: gpt-4o-mini (cost), gpt-4o (quality)
OPENAI_API_KEY=REPLACE_WITH_OPENAI_KEY

# Groq (free hosted inference — recommended for staging)
# Register: https://console.groq.com → API Keys
# Recommended models: llama-3.1-8b-instant (fast), llama-3.3-70b-versatile (quality)
GROQ_API_KEY=REPLACE_WITH_GROQ_KEY

# --- Model Context and Cost ---
# Set these for the active model so context monitoring and cost logging work correctly.
# See docs/context_and_cost_management.md for per-model reference values.
MODEL_CONTEXT_WINDOW_TOKENS=128000
# llama3.2:8b=128000 | qwen2.5:7b=32000 | llama-3.1-8b-instant=8000 | claude-*=200000 | gpt-4o=128000
MODEL_COST_INPUT_PER_M_USD=0.00
# $0.00 for Ollama/Groq free; claude-haiku=0.25; claude-sonnet=3.00; gpt-4o-mini=0.15
MODEL_COST_OUTPUT_PER_M_USD=0.00
# $0.00 for Ollama/Groq free; claude-haiku=1.25; claude-sonnet=15.00; gpt-4o-mini=0.60
MODEL_TEMPERATURE=0.1
# Fixed low temperature for prediction generation to reduce hallucination rate

# Cheap model used for normalization, extraction, and context compression summaries
AI_MODEL_PROVIDER_CHEAP=ollama
AI_MODEL_NAME_CHEAP=llama3.2

# Context compression thresholds (fraction of context window)
CONTEXT_WARNING_THRESHOLD_PCT=0.75
CONTEXT_CRITICAL_THRESHOLD_PCT=0.90
MAX_FEATURES_CRITICAL=10
CONTEXT_KEEP_TOOL_RESULTS=5

# Spend caps (USD; set to 0 to disable)
MAX_SPEND_PER_RUN_USD=0.50
MAX_SPEND_DAILY_USD=5.00

# Hallucination guards
HALLUCINATION_PROB_LOW=0.05
HALLUCINATION_PROB_HIGH=0.95
MAX_OUTPUT_VALIDATION_RETRIES=2
SELF_CONSISTENCY_ENABLED=false
SELF_CONSISTENCY_RUNS=3
SELF_CONSISTENCY_MAX_STD=0.10

# Batching and deduplication
NORMALIZATION_BATCH_SIZE=10
DEDUP_SIMILARITY_THRESHOLD=0.85
DEDUP_WINDOW_MINUTES=15

# --- AI Safety Limits ---
# See docs/ai_safety_and_loops.md for full explanation of each limit.
MAX_AGENT_TOOL_CALLS=20
MAX_AGENT_ITERATIONS=5
MAX_AGENT_INPUT_TOKENS=6000
MAX_AGENT_OUTPUT_TOKENS=2000
MAX_FEATURES_PER_PREDICTION=25
MAX_EVIDENCE_SUMMARY_CHARS=1000
JOB_MAX_RUNTIME_SECONDS=300
INGESTION_JOB_MAX_RUNTIME_SECONDS=120
PREDICTION_JOB_MAX_RUNTIME_SECONDS=180
EVALUATION_JOB_MAX_RUNTIME_SECONDS=60

# --- Logging ---
# See docs/logging_strategy.md for full format specification.
LOG_LEVEL=INFO
# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FILE_PATH=./logs/app.log
LOG_MAX_BYTES=52428800
# 50 MB per file
LOG_BACKUP_COUNT=14
# Number of rotated log files to keep
LOG_TO_STDOUT=false
# Set true in Docker/production to write to stdout instead of file

# --- Cron Schedule ---
# Intervals in seconds. See docs for recommended schedules per pipeline stage.
CRON_DISCOVERY_INTERVAL_SECONDS=43200
# 12 hours — API health check and schema discovery
CRON_PRICE_INGEST_INTERVAL_SECONDS=900
# 15 minutes — price bar ingestion
CRON_NEWS_INGEST_INTERVAL_SECONDS=3600
# 1 hour — news/event ingestion
CRON_MACRO_INGEST_INTERVAL_SECONDS=21600
# 6 hours — macro indicator check
CRON_EVALUATION_INTERVAL_SECONDS=3600
# 1 hour — evaluate expired predictions (hourly prevents >2h lag on 24h-horizon predictions)
CRON_ALERT_CHECK_INTERVAL_SECONDS=3600
# 1 hour — check for alertable predictions

# --- Alerting Thresholds ---
# These mirror the defaults seeded in ops.alert_rules.
# Changing these values overrides the DB defaults at runtime without a migration.
ALERT_MIN_PROBABILITY=0.85
ALERT_MAX_HORIZON_HOURS=72

# --- Orchestration ---
# Seconds between orchestrator polling cycles when using the job-queue approach.
ORCHESTRATOR_POLL_INTERVAL_SECONDS=60

# --- Data Retention (days, 0 = keep forever) ---
RAW_PAYLOAD_RETENTION_DAYS=365
FEATURE_SNAPSHOT_RETENTION_DAYS=730
ALERT_LOG_RETENTION_DAYS=180
EXPERIMENT_LOG_RETENTION_DAYS=730
